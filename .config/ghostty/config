background = #16181a
foreground = #ffffff
cursor-color = #ffffff
selection-background = #3c4048
selection-foreground = #ffffff


# font family
font-family = Geist Mono

# font size
font-size = 20

# opacity of split windows
unfocused-split-opacity = 0.97

# cursor style
cursor-style = block
cursor-style-blink = true

# clipboard settings
clipboard-read = allow
clipboard-write = allow

# allow option to work as alt on macos
macos-option-as-alt = true

# shows ghostty as title
title = ghostty

# window size
window-width = 90
window-height = 30

window-padding-balance = true
window-padding-x = 0
