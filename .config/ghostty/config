# background & foreground
background = #110f17
foreground = #edecee

# selection colors
selection-background = #110f17
selection-foreground = #edecee

# cursor colors
cursor-color = #edecee
cursor-text = #110f17

# black
palette = 0=#1c1b22
palette = 8=#4d4d4d

# red
palette = 1=#ff6767
palette = 9=#ff6767

# green
palette = 2=#61ffca
palette = 10=#61ffca

# yellow
palette = 3=#ffca85
palette = 11=#ffca85

# blue
palette = 4=#a277ff
palette = 12=#a277ff

# magenta
palette = 5=#a277ff
palette = 13=#a277ff

# cyan
palette = 6=#61ffca
palette = 14=#61ffca

# white
palette = 7=#edecee
palette = 15=#edecee


# font family
font-family = Geist Mono

# font size
font-size = 14

# opacity of split windows
unfocused-split-opacity = 0.97

# cursor style
cursor-style-blink = true

# clipboard settings
clipboard-read = allow
clipboard-write = allow

# allow option to work as alt on macos
macos-option-as-alt = true

# shows ghostty as title
title = ghostty

# window size
window-width = 90
window-height = 30

window-padding-balance = true
window-padding-x = 0
